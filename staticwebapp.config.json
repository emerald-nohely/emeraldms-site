{
  "routes": [
    { "route": "/index.html", "redirect": "/", "statusCode": 301 },
    { "route": "/script.js", "headers": { "Cache-Control": "public, max-age=300, must-revalidate" } },
    { "route": "/styles.css", "headers": { "Cache-Control": "public, max-age=300, must-revalidate" } },
    { "route": "/", "headers": { "Cache-Control": "public, max-age=300, must-revalidate" } }
  ],
  "trailingSlash": "never",
  "globalHeaders": {
    "Cache-Control": "public, max-age=3600",
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
